<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CofreDeSenhas.Janelas.JanelaSelecionarBanco"
        Title="Conectar banco de dados"
        Width="536"
        SizeToContent="Height"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="CenterOwner">

  <Border CornerRadius="12"
          ClipToBounds="True"
          Background="{DynamicResource CardBackground}"
          BorderBrush="{DynamicResource CardBorder}"
          BorderThickness="1">

    <DockPanel>
      <Border DockPanel.Dock="Top"
              Height="56"
              BorderBrush="{DynamicResource CardBorder}"
              BorderThickness="0,0,0,1"
              PointerPressed="Arrastar">
        <Grid>
          <TextBlock Text="Conectar banco de dados"
                     FontSize="17" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimary}"
                     VerticalAlignment="Center"
                     Margin="24,0,0,0" />
          <Button Classes="fechar-dialogo" Content="✕"
                  HorizontalAlignment="Right" VerticalAlignment="Center"
                  Margin="0,0,14,0"
                  Click="Cancelar_Click" />
        </Grid>
      </Border>

      <StackPanel Margin="24,18,24,10" Spacing="14">
        <TextBlock Text="Escolha o tipo de banco de dados para conectar."
                   FontSize="12"
                   Foreground="{DynamicResource TextSecondary}" />
        <WrapPanel Name="Grade" />
      </StackPanel>
    </DockPanel>
  </Border>
</Window>

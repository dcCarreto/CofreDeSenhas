<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="using:CofreDeSenhas.Controles"
        x:Class="CofreDeSenhas.Janelas.JanelaLogin"
        Title="Cofre de Senhas"
        Width="800" Height="700"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="CenterScreen">

  <Border Name="Moldura"
          CornerRadius="12"
          ClipToBounds="True"
          Background="{DynamicResource WorkspaceBackground}"
          BorderBrush="{DynamicResource CardBorder}"
          BorderThickness="1"
          PointerPressed="Arrastar">

    <Grid>
      <Grid Margin="18" ColumnDefinitions="360,18,*">
        <Border Grid.Column="0"
                CornerRadius="12"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="1"
                BoxShadow="0 3 16 0 #21262840">
          <c:GeradorSenha Name="Gerador" />
        </Border>

        <Border Grid.Column="2"
                CornerRadius="12"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="1"
                BoxShadow="0 3 16 0 #21262840">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch"
                      Margin="40" MaxWidth="360">
            <Image Source="/Ativos/app.png" Width="64" Height="64" HorizontalAlignment="Center" />

            <TextBlock Text="Cofre de Senhas"
                       FontSize="23" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,4" />

            <TextBlock Name="LblSubtitulo"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,26" />

            <TextBlock Text="Senha mestra"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,0,6" />
            <TextBox Name="TxtSenha"
                     Classes="campo revealPasswordButton"
                     PasswordChar="●"
                     MinHeight="42" />

            <StackPanel Name="PainelConfirmar" IsVisible="False" Margin="0,14,0,0">
              <TextBlock Text="Confirmar senha"
                         FontSize="12"
                         Foreground="{DynamicResource TextSecondary}"
                         Margin="0,0,0,6" />
              <TextBox Name="TxtConfirmar"
                       Classes="campo revealPasswordButton"
                       PasswordChar="●"
                       MinHeight="42" />
            </StackPanel>

            <TextBlock Name="LblErro"
                       FontSize="12"
                       Foreground="{DynamicResource StrengthWeak}"
                       TextWrapping="Wrap"
                       MinHeight="20"
                       Margin="0,10,0,10" />

            <Button Name="BtnPrincipal"
                    Classes="primario"
                    Height="44"
                    HorizontalAlignment="Stretch"
                    Click="Principal_Click" />
          </StackPanel>
        </Border>
      </Grid>

      <Button Name="BtnFechar"
              Classes="fechar-dialogo"
              Content="✕"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,26,26,0"
              Click="Fechar_Click" />
    </Grid>
  </Border>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CofreDeSenhas.Janelas.JanelaConexaoBanco"
        Title="Conexão"
        Width="470"
        SizeToContent="Height"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="CenterOwner">

  <Border CornerRadius="12"
          ClipToBounds="True"
          Background="{DynamicResource CardBackground}"
          BorderBrush="{DynamicResource CardBorder}"
          BorderThickness="1">

    <DockPanel>
      <Border DockPanel.Dock="Top"
              Height="56"
              BorderBrush="{DynamicResource CardBorder}"
              BorderThickness="0,0,0,1"
              PointerPressed="Arrastar">
        <Grid>
          <TextBlock Name="LblTitulo" Text="Conexão"
                     FontSize="17" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimary}"
                     VerticalAlignment="Center"
                     Margin="24,0,0,0" />
          <Button Classes="fechar-dialogo" Content="✕"
                  HorizontalAlignment="Right" VerticalAlignment="Center"
                  Margin="0,0,14,0"
                  Click="Cancelar_Click" />
        </Grid>
      </Border>

      <Border DockPanel.Dock="Bottom"
              Height="72"
              BorderBrush="{DynamicResource CardBorder}"
              BorderThickness="0,1,0,0">
        <Grid Margin="24,0">
          <Button Name="BtnTestar" Classes="secundario" Content="Testar conexão"
                  Width="150" Height="40"
                  HorizontalAlignment="Left" VerticalAlignment="Center"
                  Click="Testar_Click" />
          <StackPanel Orientation="Horizontal" Spacing="10"
                      HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button Classes="secundario" Content="Cancelar"
                    Width="100" Height="40" Click="Cancelar_Click" />
            <Button Name="BtnConectar" Classes="primario" Content="Conectar"
                    Width="120" Height="40" Click="Conectar_Click" />
          </StackPanel>
        </Grid>
      </Border>

      <StackPanel Margin="24,14,24,8">
        <StackPanel Name="Campos" />
        <TextBlock Name="LblErro"
                   FontSize="12"
                   Foreground="{DynamicResource StrengthWeak}"
                   TextWrapping="Wrap"
                   MinHeight="20"
                   Margin="0,10,0,0" />
      </StackPanel>
    </DockPanel>
  </Border>
</Window>

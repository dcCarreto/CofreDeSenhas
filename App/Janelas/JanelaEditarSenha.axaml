<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CofreDeSenhas.Janelas.JanelaEditarSenha"
        Title="Editar senha"
        Width="460"
        SizeToContent="Height"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="CenterOwner">

  <Border CornerRadius="12"
          ClipToBounds="True"
          Background="{DynamicResource CardBackground}"
          BorderBrush="{DynamicResource CardBorder}"
          BorderThickness="1">

    <DockPanel>
      <Border DockPanel.Dock="Top"
              Height="56"
              BorderBrush="{DynamicResource CardBorder}"
              BorderThickness="0,0,0,1"
              PointerPressed="Arrastar">
        <Grid>
          <TextBlock Name="LblTitulo"
                     FontSize="17" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimary}"
                     VerticalAlignment="Center"
                     Margin="24,0,60,0"
                     TextTrimming="CharacterEllipsis" />
          <Button Classes="fechar-dialogo" Content="✕"
                  HorizontalAlignment="Right" VerticalAlignment="Center"
                  Margin="0,0,14,0"
                  Click="Cancelar_Click" />
        </Grid>
      </Border>

      <Border DockPanel.Dock="Bottom"
              Height="72"
              BorderBrush="{DynamicResource CardBorder}"
              BorderThickness="0,1,0,0">
        <Grid Margin="24,0">
          <Button Classes="primario" Content="Salvar"
                  Width="200" Height="40"
                  HorizontalAlignment="Left" VerticalAlignment="Center"
                  Click="Salvar_Click" />
          <Button Classes="secundario" Content="Cancelar"
                  Width="150" Height="40"
                  HorizontalAlignment="Right" VerticalAlignment="Center"
                  Click="Cancelar_Click" />
        </Grid>
      </Border>

      <StackPanel Margin="24,18,24,16" Spacing="4">
        <TextBlock Text="Nome do serviço" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
        <TextBox Name="TxtNomeServico" Classes="campo" Margin="0,0,0,12" />

        <TextBlock Text="Usuário / E-mail" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
        <TextBox Name="TxtUsuario" Classes="campo" Margin="0,0,0,12" />

        <TextBlock Text="Senha  (deixe em branco para manter a atual)" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
        <TextBox Name="TxtSenha" Classes="campo revealPasswordButton" PasswordChar="●" Margin="0,0,0,12" />

        <TextBlock Text="Autenticação em duas etapas (2FA)  (em branco remove)" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
        <TextBox Name="TxtTotp" Classes="campo"
                 Watermark="Cole a chave secreta ou o link otpauth://" Margin="0,0,0,8" />
        <Border Name="PainelTotp" IsVisible="False"
                Background="{DynamicResource InputBackground}"
                BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Name="LblCodigoTotp" FontFamily="{DynamicResource FonteMono}"
                       FontSize="20" FontWeight="Bold" LetterSpacing="1"
                       Foreground="{DynamicResource AccentPrimary}" VerticalAlignment="Center" />
            <TextBlock Name="LblContagemTotp" Grid.Column="2" FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
          </Grid>
        </Border>

        <TextBlock Text="Categoria" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
        <ComboBox Name="CmbCategoria" Classes="campo" HorizontalAlignment="Stretch" Margin="0,0,0,12" />

        <TextBlock Text="URL  (opcional)" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
        <TextBox Name="TxtUrl" Classes="campo" Margin="0,0,0,12" />

        <TextBlock Text="Notas  (opcional)" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
        <TextBox Name="TxtNotas" Classes="campo" AcceptsReturn="True" Height="64" />
      </StackPanel>
    </DockPanel>
  </Border>
</Window>
